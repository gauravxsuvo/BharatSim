# ============================================================================
# BharatSim backend configuration
# ----------------------------------------------------------------------------
# The app runs fully on the bundled SAMPLE DATA with everything below left as-is.
# Fill in a value to switch that capability from "sample/demo" to "live".
# ============================================================================

# Database
#   Default: SQLite — runs the whole backend with NO Docker and NO PostGIS.
#   For the full PostgreSQL + PostGIS stack, start Docker (docker-compose up -d)
#   and switch to the postgres URL below.
DATABASE_URL=sqlite+aiosqlite:///./bharatsim.db
# DATABASE_URL=postgresql+asyncpg://bharatsim:bharatsim@localhost:5432/bharatsim
REDIS_URL=redis://localhost:6379/0

# AI Assistant — leave blank to serve built-in demo answers; add a key for live GPT
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Live weather data (optional) — the seed uses sample CSVs unless you enable one:
#   USE_LIVE_DATA=true            → pull real history from Open-Meteo (no key needed)
#   OPENWEATHER_API_KEY=<key>     → (also enables live data)
USE_LIVE_DATA=false
OPENWEATHER_API_KEY=

DEBUG=true
